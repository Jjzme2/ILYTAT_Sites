# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (email notifications for new inquiries) ────────────────────────────
# Sign up at resend.com — free tier covers 100 emails/day
RESEND_API_KEY=re_...
# The address that receives new inquiry notifications
NOTIFICATION_EMAIL=you@example.com
# The verified sender domain you configure in Resend
RESEND_FROM=ILYTAT Inquiries <noreply@yourdomain.com>

# ── Admin ─────────────────────────────────────────────────────────────────────
# Firebase auth handles admin login — create a user in Firebase Console under
# Authentication → Users. The /admin page signs in with email + password.

# ── App ───────────────────────────────────────────────────────────────────────
SITE_URL=https://ilytat.com

# ── Analytics (optional) ─────────────────────────────────────────────────────
# Plausible: add your domain at plausible.io, then set this to your domain string
# PLAUSIBLE_DOMAIN=ilytat.com
