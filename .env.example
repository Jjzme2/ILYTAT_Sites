# ── Firebase (client — public, used by browser & admin page) ─────────────────
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── Firebase (server — service account, used by ALL server-side Firestore reads/writes)
# WITHOUT THESE the server cannot read promotions, projects, testimonials, analytics, etc.
# They will silently return null/[] instead of throwing a visible error.
#
# How to get them:
#   Firebase Console → Project Settings → Service Accounts
#   → Generate new private key → download JSON
#   FIREBASE_CLIENT_EMAIL = client_email field in the JSON
#   FIREBASE_PRIVATE_KEY  = private_key field  (the whole -----BEGIN ... END----- block)
#
# In .env paste the private key on ONE LINE with literal \n for newlines, e.g.:
#   FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret from Stripe Dashboard → Webhooks → your endpoint → Signing secret
# Register these events: checkout.session.completed, payment_intent.payment_failed,
#                        customer.subscription.trial_will_end
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — copy from Stripe Dashboard → Products → [product] → Pricing
# One-time build fees
STRIPE_PRICE_STARTER_BUILD=price_...
STRIPE_PRICE_PROFESSIONAL_BUILD=price_...
STRIPE_PRICE_PREMIUM_BUILD=price_...
# Recurring hosting subscription prices
STRIPE_PRICE_HOSTING_MONTHLY=price_...
STRIPE_PRICE_HOSTING_YEARLY=price_...

# ── Resend (email notifications for new inquiries) ────────────────────────────
# Sign up at resend.com — free tier covers 100 emails/day
RESEND_API_KEY=re_...
# The address that receives new inquiry notifications
NOTIFICATION_EMAIL=you@example.com
# The verified sender domain you configure in Resend
RESEND_FROM=ILYTAT Inquiries <noreply@yourdomain.com>
# Sender for owner purchase/invoice notifications — set once notifications.ilytat.com is verified in Resend
# Falls back to RESEND_FROM if not set
RESEND_INVOICE_FROM=ILYTAT Invoice <noreply@notifications.ilytat.com>

# ── Cloudflare R2 (internal document storage — pricing docs, templates, etc.) ─
# Create a bucket (e.g. "ilytat-internal"), then under R2 → Manage R2 API tokens
# create a token with Object Read & Write on that bucket.
# Account ID is on the R2 dashboard overview page (right sidebar).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ilytat-internal

# ── Admin ─────────────────────────────────────────────────────────────────────
# Firebase auth handles admin login — create a user in Firebase Console under
# Authentication → Users. The /admin page signs in with email + password.

# ── App ───────────────────────────────────────────────────────────────────────
SITE_URL=https://ilytat.com

# ── Analytics (optional) ─────────────────────────────────────────────────────
# Plausible: add your domain at plausible.io, then set this to your domain string
# PLAUSIBLE_DOMAIN=ilytat.com
